# Renommez ce fichier en ".env" et remplissez vos vraies valeurs.
# Ne jamais committer le fichier ".env" sur GitHub (il est déjà ignoré).

# URL de connexion MongoDB Atlas (voir README pour l'obtenir)
MONGODB_URI=mongodb+srv://utilisateur:motdepasse@cluster0.xxxxx.mongodb.net/reda_store?retryWrites=true&w=majority

# Phrase secrète utilisée pour signer les tokens de connexion admin (mettez une chaîne longue et aléatoire)
JWT_SECRET=changez-moi-par-une-longue-phrase-secrete-aleatoire

# Port du serveur (Render le définit automatiquement, utile seulement en local)
PORT=5000

# Identifiants du compte admin créés par "npm run seed"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-ce-mot-de-passe

# URL exacte de votre site frontend (Vercel) pour autoriser les requêtes (CORS)
FRONTEND_URL=https://votre-site.vercel.app
